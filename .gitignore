# Why: local virtualenv is huge and machine-specific.
.venv/

# Why: Python bytecode and caches are generated noise.
__pycache__/
*.py[cod]
*$py.class

# Why: pytest cache is local test state, not source.
.pytest_cache/

# Why: editor and OS junk should not pollute the repo.
.DS_Store
.idea/
.vscode/

# Why: local env files may hold tokens or machine-only config.
.env
.env.*

# Why: coverage artifacts are generated outputs.
.coverage
htmlcov/
coverage.xml

# Why: runtime logs are disposable local artifacts.
*.log

# Why: fetched market data cache is reproducible local state, not source.
data_cache/

# Why: transient cross-agent (Claude Code <-> Hermes) soft-lock file, not source.
.agent-coordination.md

# Why: research run history is local state and can grow large quickly.
storage/
evolab/state/
evolab/runs.jsonl

# Why: proven-universe fixtures are fetched market data, regenerable via scripts/fetch_proven_fixtures.py.
evolab/fixtures/
# Why: proven-universe search state, same as evolab/state/.
evolab/state-proven/
# Why: live paper-trade NAV/order logs are runtime state.
execution/*.jsonl
# Why: grid NAV is runtime state (rejected-strategies.jsonl stays tracked as memory).
lanes/grid-nav.jsonl

# Why: per-asset EvoLab/hunter search state dirs are runtime state, not source.
state-binance-*/
state-hunter-*/
# Why: root-level research result logs are disposable runtime output.
/*.jsonl
# Why: silver-bullet alert dedup state is runtime, not source.
sb_alert_state.json
# Why: editor backup copies should never be committed.
*.bak
